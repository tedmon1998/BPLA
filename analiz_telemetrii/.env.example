# Код награды — только на сервере (не префикс VITE_)
REWARD_CODE=FLT-45SEC

# Ожидаемый ответ: ISO 3166-1 alpha-2 страны по координатам из точки аномалии (не в бандле)
EXPECTED_COUNTRY_ISO2=IR

# SHA-256 от кода активации (сам код не хранить в файлах проекта)
ACTIVATION_CODE_HASH=replace_with_sha256_hex

# Путь к каноническому CSV для серверной проверки (по умолчанию: public/data/telemetry.csv или dist после сборки)
# TELEMETRY_PATH=F:/path/to/telemetry.csv

# Для раздачи по HTTPS: флаг Secure у cookie сессии
# COOKIE_SECURE=1

PORT=3000
