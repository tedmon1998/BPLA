{
  "name": "planirovshik_marshruta",
  "private": true,
  "version": "0.0.0",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:client\" \"npm:dev:server\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "tsc -b && vite build",
    "electron:dev": "concurrently -k \"npm:dev:server\" \"npm:dev:client\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "npm run build && npm run bundle:server && electron-builder --win",
    "bundle:server": "esbuild server/index.ts --bundle --platform=node --target=node18 --format=cjs --legal-comments=none --outfile=dist-server/server.cjs",
    "build:server-exe": "npm run bundle:server && pkg dist-server/server.cjs --targets node18-win-x64 --output release-server-api/MissionApi.exe",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.bpla.planirovshik",
    "productName": "PlanirovshikMarshruta",
    "files": [
      "dist/**/*",
      "dist-server/**/*",
      "electron/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "dist-server/**"
    ],
    "win": {
      "target": [
        "portable"
      ],
      "signAndEditExecutable": false
    }
  },
  "dependencies": {
    "@turf/turf": "^7.3.4",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "leaflet": "^1.9.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.6.0",
    "react-leaflet": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^37.5.0",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "pkg": "^5.8.1",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "wait-on": "^8.0.5"
  }
}
